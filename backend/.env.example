APP_NAME=Procurement Analytics API
ENVIRONMENT=development
DEBUG=true

MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_USER=procurement
MYSQL_PASSWORD=procurement
MYSQL_DATABASE=procurement_db
MYSQL_CHARSET=utf8mb4

# Optional: use this instead of MYSQL_* variables
# DATABASE_URL=mysql+pymysql://procurement:procurement@db:3306/procurement_db?charset=utf8mb4

CORS_ORIGINS_RAW=http://localhost:3000,http://localhost:5173
UPLOAD_MAX_SIZE_MB=20
LOG_LEVEL=INFO
